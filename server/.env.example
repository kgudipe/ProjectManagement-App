# ---- Core ----
PORT=8000
NODE_ENV=development

# PostgreSQL connection string (Prisma). For local dev or RDS/Neon/Supabase.
DATABASE_URL=postgresql://user:password@localhost:5432/project_management?schema=public

# ---- AWS Cognito (auth) ----
# Used to verify the Bearer JWT sent by the frontend.
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# Set to "true" to require a valid Cognito JWT on protected routes.
# Leave "false" for local development without Cognito.
AUTH_ENABLED=false

# ---- AWS S3 (attachments) ----
S3_BUCKET_NAME=project-management-attachments
# Credentials are taken from the standard AWS provider chain (instance role,
# env vars, or ~/.aws/credentials). Only set these for local dev if needed.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
